---
---
<section id="lessons">
  <div class="wrap">
    <h2>Learn drums &amp; production.</h2>
    <div class="card">
      <div class="copy">
        <p>
          Drum lessons from hip-hop to pop — Dilla swing, groove &amp; phrasing,
          playing in bands — plus mixing and producing with Logic &amp; Ableton
          Live. In Zurich, for beginners and advanced players, in German or
          English.
        </p>
        <div class="chips">
          <span class="chip chip-lavender">Drum lessons</span>
          <span class="chip chip-turquoise">Groove &amp; phrasing</span>
          <span class="chip chip-pink">Logic &amp; Ableton</span>
        </div>
        <a
          class="cta"
          href="https://www.instrumentor.ch/de/david-kraehenbuehl"
          target="_blank"
          rel="noopener"
        >Book a trial lesson on Instrumentor ↗</a>
      </div>
      <div class="photo">
        <img src="/images/david-kraehenbuehl_fourfive_with_tagline_92ba.jpg" alt="David Krähenbühl teaching drums" loading="lazy" />
      </div>
    </div>
  </div>
</section>

<style>
  section { padding: 110px 32px 0; }
  .card {
    border: 3px solid var(--ink);
    border-radius: 20px;
    background: var(--surface);
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    overflow: hidden;
    box-shadow: 8px 8px 0 var(--ink);
  }
  .copy {
    padding: clamp(28px, 4vw, 48px);
    display: flex;
    flex-direction: column;
    gap: 20px;
    justify-content: center;
  }
  .copy p {
    font-size: 16px;
    line-height: 1.7;
    margin: 0;
  }
  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .chip {
    border: 2px dashed var(--ink);
    border-radius: 999px;
    padding: 4px 14px;
    font-size: 13px;
  }
  .chip-lavender { background: var(--lavender); }
  .chip-turquoise { background: var(--turquoise); }
  .chip-pink { background: var(--pink); }
  .cta {
    align-self: flex-start;
    text-decoration: none;
    background: var(--ink);
    color: var(--yellow);
    font-size: 15px;
    padding: 14px 26px;
    border-radius: 999px;
    border: 3px solid var(--ink);
    transition: background 0.2s, color 0.2s;
  }
  .cta:hover {
    background: var(--violet);
    color: #fff;
  }
  .photo {
    border-left: 3px solid var(--ink);
    min-height: 320px;
    background: var(--surface);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(20px, 3vw, 40px);
  }
  .photo img {
    max-width: 100%;
    max-height: 400px;
    width: auto;
    height: auto;
    border: 3px solid var(--ink);
    border-radius: 12px;
    box-shadow: 6px 6px 0 var(--ink);
  }
  @media (max-width: 760px) {
    .card { grid-template-columns: 1fr; }
    .photo {
      border-left: none;
      border-top: 3px solid var(--ink);
      min-height: 260px;
    }
  }
</style>
