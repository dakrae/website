---
---
<section class="hero">
  <div class="wrap hero-inner">
    <div class="hero-text">
      <p class="eyebrow" aria-hidden="true">
        <span class="beat is-one">1</span><span class="beat">2</span><span class="beat">3</span><span class="beat">4</span>
      </p>
      <h1>David Krähenbühl</h1>
      <p class="role">Schlagzeuger · Zürich</p>
      <p class="bio">
        <!-- TODO Dave: durch deinen eigenen Bio-Text ersetzen (2-4 Sätze). -->
        David Krähenbühl ist Schlagzeuger aus Zürich, unterwegs als gefragter
        Sideman und als Co-Bandleader des Instrumental-Trios loophole. Sein
        Spiel ist groovy und atmosphärisch, geprägt von Musiker:innen wie
        BADBADNOTGOOD, Yussef Dayes und Tom Misch.
      </p>
    </div>
    <div class="hero-media">
      <!-- TODO Dave: /public/images/hero.jpg ersetzen -->
      <img src="/images/hero.jpg" alt="David Krähenbühl am Schlagzeug" />
    </div>
  </div>
</section>

<style>
  .hero {
    border-top: none;
    padding-top: clamp(3rem, 8vw, 6rem);
  }
  .hero-inner {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  h1 {
    font-size: clamp(2.6rem, 6vw, 4.4rem);
    line-height: 1.05;
    margin-bottom: 0.4rem;
  }
  .role {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--accent);
    margin: 0 0 1.5rem;
    letter-spacing: 0.04em;
  }
  .bio {
    max-width: var(--measure);
    color: var(--text-muted);
    font-size: 1.05rem;
  }
  .hero-media img {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    background: var(--surface);
    border: 1px solid var(--surface-line);
  }
  @media (max-width: 780px) {
    .hero-inner { grid-template-columns: 1fr; }
    .hero-media { order: -1; max-width: 60%; }
  }
</style>
