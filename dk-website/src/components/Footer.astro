---
const year = new Date().getFullYear();
---
<footer>
  <span>© {year} David Krähenbühl</span>
  <a href="https://www.instagram.com/davidkrae/" target="_blank" rel="noopener">Instagram ↗</a>
</footer>

<style>
  footer {
    border-top: 3px solid var(--ink);
    padding: 24px 32px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 13px;
    background: var(--ink);
    color: var(--lavender-pale);
  }
  footer a {
    color: var(--yellow);
    text-decoration: none;
  }
  footer a:hover { color: #fff; }
</style>
