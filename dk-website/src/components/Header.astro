<nav class="nav">
  <a href="#top" class="wordmark">DAVID KRÄHENBÜHL ●</a>
  <div class="links">
    <a href="#collaborations">Collaborations</a>
    <a href="#live">Live</a>
    <a href="#lessons">Lessons</a>
    <a href="#contact">Contact</a>
    <a
      class="insta"
      href="https://www.instagram.com/davidkrae/"
      target="_blank"
      rel="noopener"
    >Instagram ↗</a>
  </div>
</nav>

<style>
  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 20px 32px;
    border-bottom: 3px solid var(--ink);
    position: sticky;
    top: 0;
    background: var(--page-bg);
    z-index: 50;
  }
  .nav a { text-decoration: none; }
  .wordmark {
    font-size: 15px;
    font-weight: bold;
    letter-spacing: 0.02em;
    white-space: nowrap;
  }
  .wordmark:hover { color: var(--ink); }
  .links {
    display: flex;
    align-items: center;
    gap: 28px;
    font-size: 13px;
    text-transform: uppercase;
  }
  .links a:hover {
    color: var(--violet);
    text-decoration: underline wavy;
  }
  .insta {
    background: var(--ink);
    color: var(--yellow);
    padding: 2px 10px;
    border-radius: 999px;
  }
  .links a.insta:hover {
    background: var(--pink);
    color: var(--ink);
    text-decoration: none;
  }
  @media (max-width: 720px) {
    .nav { flex-wrap: wrap; padding: 14px 20px; }
    .links { flex-wrap: wrap; gap: 10px 16px; }
  }
</style>
