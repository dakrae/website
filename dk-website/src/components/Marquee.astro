---
const line = 'Live shows ✳ Studio sessions ✳ New projects ✳ loophole ✳ James Gruntz ✳ Marlin ✳ ';
---
<div class="band" aria-hidden="true">
  <div class="track">
    <span>{line}</span>
    <span>{line}</span>
  </div>
</div>

<style>
  .band {
    margin-top: 80px;
    background: var(--ink);
    color: var(--yellow);
    overflow: hidden;
    border-top: 3px solid var(--ink);
    border-bottom: 3px solid var(--ink);
    transform: rotate(-1deg) scale(1.02);
  }
  .track {
    display: flex;
    width: max-content;
    animation: marquee 22s linear infinite;
    padding: 14px 0;
    font-size: 18px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    white-space: nowrap;
  }
  .track span { padding-right: 32px; }
</style>
