---
// TODO Dave: replace email address.
const email = "hallo@davidkraehenbuehl.ch";
---
<section id="contact">
  <div class="wrap card">
    <p class="eyebrow">(04) Contact</p>
    <h2>Get in touch.</h2>
    <p class="lead">
      Open to live shows, studio sessions, and new projects.
    </p>
    <a class="mail" href={`mailto:${email}`}>{email} ↗</a>
    <div class="wobble-star" aria-hidden="true">✳</div>
  </div>
</section>

<style>
  section { padding: 120px 32px; }
  .card {
    background: var(--turquoise);
    border: 3px solid var(--ink);
    border-radius: 28px;
    padding: clamp(40px, 6vw, 80px);
    box-shadow: 10px 10px 0 var(--ink);
    position: relative;
  }
  h2 {
    font-size: clamp(40px, 6vw, 80px);
    margin: 12px 0 20px;
  }
  .lead {
    font-size: 16px;
    margin: 0 0 36px;
    max-width: 480px;
    line-height: 1.7;
  }
  .mail {
    display: inline-block;
    text-decoration: none;
    background: var(--ink);
    color: var(--yellow);
    font-size: clamp(16px, 2.2vw, 24px);
    padding: 18px 32px;
    border-radius: 999px;
    border: 3px solid var(--ink);
    transition: background 0.2s, color 0.2s, transform 0.2s;
  }
  .mail:hover {
    background: var(--pink);
    color: var(--ink);
    transform: rotate(-1.5deg);
  }
  .wobble-star {
    position: absolute;
    top: -28px;
    right: 48px;
    font-size: 56px;
    color: var(--violet);
    animation: wobble 4s ease-in-out infinite;
    user-select: none;
  }
</style>
