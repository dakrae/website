---
// TODO Dave: replace email address.
const email = "hallo@davidkraehenbuehl.ch";
---
<section id="contact">
  <div class="wrap">
    <p class="eyebrow">Contact</p>
    <h2>Get in touch.</h2>
    <p class="lead">
      Open to live shows, studio sessions, and new projects.
    </p>
    <a class="mail" href={`mailto:${email}`}>
      <span class="mail-text">{email}</span>
      <span class="arrow" aria-hidden="true">↗</span>
    </a>
  </div>
</section>

<style>
  .lead {
    max-width: var(--measure);
    color: var(--text-muted);
    margin: 1.5rem 0 3rem;
    font-size: 1.1rem;
  }
  .mail {
    display: inline-flex;
    align-items: baseline;
    gap: 0.6rem;
    font-family: var(--font-display);
    font-weight: 500;
    letter-spacing: -0.01em;
    font-size: clamp(1.6rem, 4vw, 2.6rem);
    line-height: 1.1;
    color: var(--text);
    transition: color 0.25s ease;
  }
  .mail-text {
    background-image: linear-gradient(var(--accent), var(--accent));
    background-position: 0 100%;
    background-repeat: no-repeat;
    background-size: 0% 2px;
    transition: background-size 0.3s ease;
    padding-bottom: 0.1em;
  }
  .mail:hover { color: var(--accent); }
  .mail:hover .mail-text { background-size: 100% 2px; }
  .mail .arrow {
    font-size: 0.7em;
    color: var(--text-muted);
    transition: transform 0.25s ease, color 0.25s ease;
  }
  .mail:hover .arrow {
    color: var(--accent);
    transform: translate(3px, -3px);
  }
</style>
