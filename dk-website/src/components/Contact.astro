---
// TODO Dave: replace email address.
const email = "hallo@davidkraehenbuehl.ch";
---
<section id="contact">
  <div class="wrap">
    <p class="eyebrow">Contact</p>
    <h2>Get in touch.</h2>
    <p class="lead">
      Open to live shows, studio sessions, and new projects.
    </p>
    <a class="mail" href={`mailto:${email}`}>{email} ↗</a>
  </div>
</section>

<style>
  .lead {
    max-width: var(--measure);
    color: var(--text-muted);
    margin: 1.25rem 0 2rem;
  }
  .mail {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 1.05rem;
    background: var(--accent-soft);
    color: var(--accent);
    border-radius: 999px;
    padding: 0.7rem 1.5rem;
    transition: transform 0.15s ease;
  }
  .mail:hover { transform: rotate(-1deg) scale(1.03); }
</style>
