---
import { getCollection } from 'astro:content';
const entries = (await getCollection('collaborations')).sort(
  (a, b) => a.data.order - b.data.order
);
---
<section id="collaborations">
  <div class="wrap">
    <div class="section-head">
      <p class="eyebrow">Collaborations</p>
      <h2>I also play with.</h2>
    </div>
    <ul class="collab-list">
      {entries.map((entry, i) => (
        <li class="collab-row">
          <span class="idx">{String(i + 1).padStart(2, '0')}</span>
          {entry.data.url ? (
            <a class="name" href={entry.data.url} target="_blank" rel="noopener">
              <span class="name-text">{entry.data.name}</span>
              <span class="arrow" aria-hidden="true">↗</span>
            </a>
          ) : (
            <span class="name"><span class="name-text">{entry.data.name}</span></span>
          )}
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .collab-list {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--surface-line);
  }
  .collab-row {
    border-bottom: 1px solid var(--surface-line);
  }
  .collab-row {
    display: grid;
    grid-template-columns: 3.5rem 1fr;
    align-items: baseline;
    padding-block: 1.4rem;
  }
  .idx {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-muted);
    padding-top: 0.5rem;
  }
  .name {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1.5rem;
    font-family: var(--font-display);
    font-weight: 500;
    letter-spacing: -0.01em;
    font-size: clamp(1.8rem, 5vw, 3rem);
    line-height: 1;
    transition: color 0.25s ease;
  }
  a.name:hover { color: var(--accent); }
  .arrow {
    font-size: 1.2rem;
    color: var(--text-muted);
    transition: transform 0.25s ease, color 0.25s ease;
  }
  a.name:hover .arrow {
    color: var(--accent);
    transform: translate(3px, -3px);
  }
</style>
