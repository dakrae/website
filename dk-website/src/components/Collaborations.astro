---
import { getCollection } from 'astro:content';
const entries = (await getCollection('collaborations')).sort(
  (a, b) => a.data.order - b.data.order
);
const chips = ['var(--lavender)', 'var(--turquoise)', 'var(--pink)'];
const tints = ['#E4DCF8', '#B4F4E9', '#FCC4DE'];
---
<section id="collaborations">
  <div class="wrap">
    <h2>I currently play with.</h2>
    <div class="grid">
      {entries.map((entry, i) => {
        const Tag = entry.data.url ? 'a' : 'div';
        const attrs = entry.data.url
          ? { href: entry.data.url, target: '_blank', rel: 'noopener' }
          : {};
        return (
          <Tag class="card" style={`--chip:${chips[i % chips.length]};--tint:${tints[i % tints.length]}`} {...attrs}>
            <span class="photo">
              {entry.data.image ? (
                <img src={entry.data.image} alt={entry.data.name} loading="lazy" />
              ) : (
                <span class="photo-ph" aria-hidden="true">{entry.data.name}</span>
              )}
            </span>
            <span class="row">
              {entry.data.name}
              {entry.data.url && <span class="arrow" aria-hidden="true">↗</span>}
            </span>
          </Tag>
        );
      })}
    </div>
  </div>
</section>

<style>
  section { padding: 100px 32px 0; }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 20px;
  }
  .card {
    text-decoration: none;
    border: 3px solid var(--ink);
    border-radius: 20px;
    background: var(--surface);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transition: transform 0.2s, box-shadow 0.2s;
    color: inherit;
  }
  a.card:hover {
    transform: translateY(-6px);
    box-shadow: 8px 8px 0 var(--chip);
    color: inherit;
  }
  .photo {
    display: block;
    aspect-ratio: 4 / 3;
    border-bottom: 3px solid var(--ink);
    position: relative;
    background: var(--tint);
  }
  .photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    position: absolute;
    inset: 0;
  }
  .photo-ph {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    font-size: 15px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--ink) 55%, transparent);
  }
  .row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 8px;
    padding: 20px 22px;
    font-size: 20px;
  }
  .arrow {
    color: var(--chip);
    -webkit-text-stroke: 1px var(--ink);
    font-size: 24px;
  }
  @media (max-width: 760px) {
    .grid { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 14px; }
    .row { padding: 12px 14px; font-size: 15px; }
  }
</style>
