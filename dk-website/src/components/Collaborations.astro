---
import { getCollection } from 'astro:content';
const entries = (await getCollection('collaborations')).sort(
  (a, b) => a.data.order - b.data.order
);
---
<section id="collaborations">
  <div class="wrap">
    <div class="section-head">
      <p class="eyebrow">Collaborations</p>
      <h2>I also play with.</h2>
    </div>
    <ul class="collab-list">
      {entries.map((entry, i) => (
        <li class={`chip chip-${i % 3}`}>
          {entry.data.url ? (
            <a href={entry.data.url} target="_blank" rel="noopener">
              {entry.data.name}
            </a>
          ) : (
            <span>{entry.data.name}</span>
          )}
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .collab-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem 1rem;
  }
  .chip {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.05rem, 2vw, 1.3rem);
    border-radius: 999px;
    padding: 0.6rem 1.4rem;
    transform: rotate(-2deg);
    transition: transform 0.15s ease;
  }
  .chip:nth-child(even) { transform: rotate(2deg); }
  .chip:hover { transform: rotate(0deg) scale(1.04); }
  .chip-0 { background: var(--accent); color: var(--bg); }
  .chip-1 { background: var(--accent-deep-soft); color: var(--accent-deep); }
  .chip-2 { background: var(--pop-yellow); color: var(--text); }
</style>
