---
import { getCollection } from 'astro:content';
const entries = (await getCollection('collaborations')).sort(
  (a, b) => a.data.order - b.data.order
);
const accents = ['var(--accent)', 'var(--accent-deep)', 'var(--accent-alt)'];
---
<section id="collaborations">
  <div class="wrap">
    <div class="section-head">
      <p class="eyebrow">Collaborations</p>
      <h2>I currently play with.</h2>
    </div>
    <ul class="collab-grid">
      {entries.map((entry, i) => {
        const Tag = entry.data.url ? 'a' : 'div';
        const attrs = entry.data.url
          ? { href: entry.data.url, target: '_blank', rel: 'noopener' }
          : {};
        return (
          <li>
            <Tag class="card" {...attrs}>
              <div class="thumb" style={`--ph:${accents[i % accents.length]}`}>
                {entry.data.image ? (
                  <img src={entry.data.image} alt={entry.data.name} loading="lazy" />
                ) : (
                  <span class="thumb-empty" aria-hidden="true">{entry.data.name.charAt(0)}</span>
                )}
              </div>
              <div class="meta">
                <span class="name">{entry.data.name}</span>
                {entry.data.url && <span class="arrow" aria-hidden="true">↗</span>}
              </div>
            </Tag>
          </li>
        );
      })}
    </ul>
  </div>
</section>

<style>
  .collab-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1.5rem, 3vw, 2.5rem);
  }
  .card {
    display: block;
    color: inherit;
  }
  .thumb {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: var(--surface);
  }
  .thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .thumb-empty {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(3rem, 7vw, 5rem);
    color: color-mix(in srgb, var(--ph) 55%, transparent);
    background:
      radial-gradient(120% 120% at 30% 20%,
        color-mix(in srgb, var(--ph) 14%, var(--surface)),
        var(--surface));
  }
  a.card:hover .thumb img { transform: scale(1.04); }
  .meta {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 1rem;
  }
  .name {
    font-family: var(--font-display);
    font-weight: 500;
    letter-spacing: -0.01em;
    font-size: clamp(1.2rem, 2.4vw, 1.6rem);
    line-height: 1.1;
    transition: color 0.25s ease;
  }
  .arrow {
    font-size: 1rem;
    color: var(--text-muted);
    transition: transform 0.25s ease, color 0.25s ease;
  }
  a.card:hover .name { color: var(--accent); }
  a.card:hover .arrow {
    color: var(--accent);
    transform: translate(3px, -3px);
  }
  @media (max-width: 720px) {
    .collab-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 460px) {
    .collab-grid { grid-template-columns: 1fr; }
  }
</style>
