---
import { getCollection } from 'astro:content';
const entries = (await getCollection('collaborations')).sort(
  (a, b) => a.data.order - b.data.order
);
---
<section id="kollaborationen">
  <div class="wrap">
    <div class="section-head">
      <p class="eyebrow">Kollaborationen</p>
      <h2>Ich spiele mit.</h2>
    </div>
    <ul class="collab-list">
      {entries.map((entry) => (
        <li>
          {entry.data.url ? (
            <a class="link-underline" href={entry.data.url} target="_blank" rel="noopener">
              {entry.data.name}
            </a>
          ) : (
            <span>{entry.data.name}</span>
          )}
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .collab-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 2.5rem;
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.4rem, 3vw, 2rem);
  }
</style>
