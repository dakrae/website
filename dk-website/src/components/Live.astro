---
import { getCollection } from 'astro:content';

// Parse "DD.MM.YYYY" (or "DD.MM.YY") into a sortable timestamp;
// unparseable dates sort to the end.
function dateKey(date: string): number {
  const m = date.trim().match(/^(\d{1,2})\.(\d{1,2})\.(\d{2,4})$/);
  if (!m) return Number.MAX_SAFE_INTEGER;
  const [, d, mo, y] = m;
  const year = y.length === 2 ? 2000 + Number(y) : Number(y);
  return new Date(year, Number(mo) - 1, Number(d)).getTime();
}

const shows = (await getCollection('shows')).sort(
  (a, b) => dateKey(a.data.date) - dateKey(b.data.date)
);
---
<section id="live">
  <div class="wrap">
    <h2>Upcoming shows.</h2>
    <div class="table-card">
      {shows.map((show) => (
        <div class="row">
          <span class="date">{show.data.date}</span>
          <span class="band">{show.data.act}</span>
          <span class="venue">
            {show.data.url ? (
              <a href={show.data.url} target="_blank" rel="noopener">
                {show.data.venue}
              </a>
            ) : (
              show.data.venue
            )}
          </span>
          <span class="city">{show.data.city} ●</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  section { padding: 110px 32px 0; }
  .table-card {
    border: 3px solid var(--ink);
    border-radius: 20px;
    overflow: hidden;
    background: var(--surface);
    box-shadow: 8px 8px 0 var(--shadow);
  }
  .row {
    display: grid;
    grid-template-columns: 110px 1fr 1fr 120px;
    gap: 16px;
    align-items: baseline;
    padding: 18px 24px;
    border-bottom: 2px dashed var(--ink);
    font-size: 15px;
    transition: background 0.15s, color 0.15s;
  }
  .row:hover {
    background: var(--violet);
    color: var(--yellow);
  }
  .row:hover a { color: var(--yellow); }
  .date { font-size: 13px; }
  .band {
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .city {
    text-align: right;
    font-size: 13px;
  }
  @media (max-width: 760px) {
    .row {
      display: flex;
      flex-wrap: wrap;
      gap: 2px 12px;
      padding: 14px 16px;
      font-size: 13px;
    }
    .city { margin-left: auto; }
  }
</style>
