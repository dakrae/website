---
import { getCollection } from 'astro:content';
// Note: sorting by date makes sense once real dates (DD.MM.YY) are entered.
const shows = await getCollection('shows');
---
<section id="live">
  <div class="wrap">
    <p class="eyebrow">(02) Live</p>
    <h2>Upcoming shows.</h2>
    <div class="table-card">
      {shows.map((show) => (
        <div class="row">
          <span class="date">{show.data.date}</span>
          <span class="band">{show.data.act}</span>
          <span class="venue">
            {show.data.url ? (
              <a href={show.data.url} target="_blank" rel="noopener">
                {show.data.venue}
              </a>
            ) : (
              show.data.venue
            )}
          </span>
          <span class="city">{show.data.city} ●</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  section { padding: 110px 32px 0; }
  .table-card {
    border: 3px solid var(--ink);
    border-radius: 20px;
    overflow: hidden;
    background: var(--card-bg);
  }
  .row {
    display: grid;
    grid-template-columns: 110px 1fr 1fr 120px;
    gap: 16px;
    align-items: center;
    padding: 18px 24px;
    border-bottom: 2px dashed var(--ink);
    font-size: 15px;
    transition: background 0.15s, color 0.15s;
  }
  .row:hover {
    background: var(--violet);
    color: var(--yellow);
  }
  .row:hover a { color: var(--yellow); }
  .date { font-size: 13px; }
  .band {
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .city {
    text-align: right;
    font-size: 13px;
  }
  @media (max-width: 640px) {
    .row {
      grid-template-columns: 1fr auto;
      grid-template-areas:
        "date city"
        "band band"
        "venue venue";
      row-gap: 4px;
    }
    .date { grid-area: date; }
    .city { grid-area: city; }
    .band { grid-area: band; }
    .venue { grid-area: venue; }
  }
</style>
